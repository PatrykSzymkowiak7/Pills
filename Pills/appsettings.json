{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Features": {
    "EnablePillTypeDelete": true,
    "EnablePillStatistics": false,
    "EnableSoftDelete": true,
    "EnableDailyReport": true
  },
  "CleanupOptions": {
    "RetentionDays": 30,
    "IntervalMinutes": 60
  }
}
