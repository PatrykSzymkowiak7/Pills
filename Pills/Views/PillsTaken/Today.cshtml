@using Pills.Domain.Models.ViewModels.PillsTaken
@model List<TodayPillViewModel>

<div class="card shadow-sm">
    <div class="card-body">

        <h3 class="text-center mb-4">
            Today - @DateTime.Today.ToString("dd/MM/yyyy")
        </h3>

        @foreach (var pill in Model)
        {
            <div class="d-flex justify-content-between align-items-center border rounded p-3 mb-2">

                <!-- LEFT SIDE -->
                <div>
                    <strong>@pill.Name</strong>

                    @if (pill.MultipleAllowed)
                    {
                        <div class="text-muted small">
                            Taken today: @pill.TakenCountToday / @pill.MaxAllowed
                        </div>
                    }
                </div>

                <!-- RIGHT SIDE -->
                <div>

                    @if (pill.Taken && !pill.MultipleAllowed)
                    {
                        <span class="badge bg-success">
                            ✔ Taken
                        </span>
                    }
                    else if (pill.MultipleAllowed)
                    {
                        if (pill.CanTake)
                        {
                            <form asp-controller="PillsTaken"
                                    asp-action="Take"
                                    method="post"
                                    class="d-inline">

                                @Html.AntiForgeryToken()

                                <input type="hidden"
                                        name="pillTypeId"
                                        value="@pill.PillTypeId" />

                                <button type="submit"
                                        class="btn btn-sm btn-primary">
                                    Take next
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="badge bg-success">
                                Max dose reached
                            </span>
                        }
                    }
                    else
                    {
                        <form asp-controller="PillsTaken"
                                asp-action="Take"
                                method="post"
                                class="d-inline">

                            @Html.AntiForgeryToken()

                            <input type="hidden"
                                    name="pillTypeId"
                                    value="@pill.PillTypeId" />

                            <button type="submit"
                                    class="btn btn-sm btn-success">
                                Mark as taken
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>
</div>