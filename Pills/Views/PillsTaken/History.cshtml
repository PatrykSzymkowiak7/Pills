@using Pills.Web.ViewModels.PillsTaken
@model HistoryPagedViewModel

<div class="card shadow-sm">
    <div class="card-body">

        <h3 class="text-center mb-4">
            History
        </h3>

        <!-- FILTER -->
        <form method="get"
                asp-action="History"
                class="row g-3 mb-4 justify-content-center">

            <div class="col-md-6">
                <label class="form-label">
                    Filter by pill type
                </label>

                <select name="pillTypeId"
                        class="form-select"
                        asp-items="Model.PillTypes">

                    <option value="">
                        -- All pills --
                    </option>
                </select>
            </div>

            <div class="col-md-3 align-self-end">
                <button type="submit"
                        class="btn btn-primary w-100">
                    Filter
                </button>
            </div>
        </form>

        <!-- TABLE -->
        <div class="table-responsive">

            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Pills taken</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var day in Model.Days)
                    {
                        <tr>
                            <td>
                                <strong>
                                    @day.Date.ToString("dd/MM/yyyy")
                                </strong>
                            </td>

                            <td>
                                @foreach (var pill in day.PillsTaken)
                                {
                                    <span class="badge bg-primary me-1 mb-1">
                                        @pill
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>

        <!-- PAGINATION -->
        <nav class="d-flex justify-content-center mt-3">

            <ul class="pagination">

                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                        asp-action="History"
                        asp-route-page="@(Model.CurrentPage - 1)"
                        asp-route-pillTypeId="@Model.SelectedPillTypeId">
                        Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                            asp-action="History"
                            asp-route-page="@i"
                            asp-route-pillTypeId="@Model.SelectedPillTypeId">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                        asp-action="History"
                        asp-route-page="@(Model.CurrentPage + 1)"
                        asp-route-pillTypeId="@Model.SelectedPillTypeId">
                        Next
                    </a>
                </li>

            </ul>

        </nav>

    </div>
</div>