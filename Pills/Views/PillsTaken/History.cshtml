@using Pills.Models.ViewModels.PillsTaken
@model HistoryPagedViewModel

<h1 class="mb-4">History</h1>

<form method="get" asp-action="History" class="row g-3 mb-4">
    <div class="col-md-4">
        <label class="form-label">Filter by pill type</label>
        <select name="pillTypeId" class="form-select" asp-items="Model.PillTypes">
            <option value="">-- All pills --</option>
        </select>
    </div>

    <div class="col-md-2 align-self-end">
        <button type="submit" class="btn btn-primary w-100">
            Filter
        </button>
    </div>
</form>

<table class="table table-striped table-hover w-auto">
    <thead class="table-light">
        <tr>
            <th>Date</th>
            <th>Pills taken</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var day in Model.Days)
        {
            <tr>
                <td>@day.Date.ToString("dd/MM/yyyy")</td>
                <td>
                    @foreach(var pill in day.PillsTaken)
                    {
                        <span class="badge bg-primary me-1">@pill</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
<nav>
    <ul class="pagination">
        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
            <a class="page-link" asp-action="History" asp-route-page="@(Model.CurrentPage - 1)">
                Previous
            </a>
        </li>

        @for(int i = 1; i<=Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                <a class="page-link" asp-action="History" asp-route-page="@i">
                    @i
                </a>
            </li>
        }

        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
            <a class="page-link" asp-action="History" asp-route-page="@(Model.CurrentPage+1)">
                Next
            </a>
        </li>

    </ul>
</nav>