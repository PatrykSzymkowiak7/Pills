@using Pills.Models.ViewModels.PillTypes
@model List<PillTypeHubViewModel>

<h1>Zarządzaj tabletkami</h1>

<table class="table table-striped table-hover w-auto">
    <thead class="table-light">
        <tr>
            <th>Nazwa tabletki</th>
            <th>Maksymalna dzienna dawka</th>
            <th>Liczba wziętych tabletek</th>
            <th>Akcja</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var pillType in Model)
        {
            <tr>
                <td>@pillType.Name</td>
                <td>@pillType.MaxAllowed</td>
                <td>@pillType.Count</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@pillType.Id" class="btn btn-primary btn-sm">
                        Edytuj
                    </a>
                    <a asp-action="ConfirmDelete" asp-route-id="@pillType.Id" class="btn btn-danger btn-sm">
                        Usuń
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
