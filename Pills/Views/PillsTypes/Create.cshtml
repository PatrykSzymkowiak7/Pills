@using Pills.Models.ViewModels.PillTypes
@model CreatePillTypeViewModel

<h1>Add new pill</h1>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MaxAllowed" class="form-label"></label>
        <input asp-for="MaxAllowed" class="form-control" />
        <span asp-validation-for="MaxAllowed" class="text-danger"></span>
        <div class="form-text">
            If > 1, pill can be taken multiple times daily
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Dodaj</button>
</form>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
