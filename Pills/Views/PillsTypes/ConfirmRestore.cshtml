@using Pills.Models.ViewModels.PillTypes
@model RestorePillTypeViewModel

<div class="card shadow-sm">
    <div class="card-body text-center">

        <h3 class="mb-4">
            Are you sure you want restore this pill type?
        </h3>

        <div class="alert alert-warning">
            <strong>@Model.Name</strong><br />
            Taken <strong>@Model.Count</strong> times
        </div>

        <form 
            asp-action="RestoreConfirmed" 
            method="post"
            class="d-flex justify-content-center gap-2">

            @Html.AntiForgeryToken()

            <input type="hidden" name="id" value="@Model.Id" />

            <button type="submit" class="btn btn-warning">
                Restore
            </button>

            <a asp-action="PillTypeHub" class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>
</div>

