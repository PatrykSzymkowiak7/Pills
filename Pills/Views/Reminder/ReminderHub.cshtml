@using Pills.Web.ViewModels.Reminders
@model List<RemindersViewModel>

<div class="card shadow-sm">
    <div class="card-body">

        <h3 class="text-center mb-4">
            Manage Reminders
        </h3>

        <table class="table table-striped table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Message</th>
                    <th>Time of day</th>
                    <th>Status</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var reminder in Model)
                {
                    <tr>
                        <td>@reminder.Message</td>

                        <td>
                            @reminder.TimeOfDay.ToString(@"hh\:mm")
                        </td>

                        <td>
                            @if (reminder.IsEnabled)
                            {
                                <span class="badge bg-success">
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    Disabled
                                </span>
                            }
                        </td>

                        <td class="text-end">

                            <a asp-action="ConfirmDelete" 
                                asp-route-id="@reminder.Id"
                                class="btn-outline-danger btn-sm">
                                Delete
                            </a>

                            <a asp-action="Edit"
                                asp-route-id="@reminder.Id"
                                class="btn btn-outline-info btn-sm">
                                Edit
                            </a>

                            @if (reminder.IsEnabled)
                            {
                                <a asp-action="ToggleReminder"
                                    asp-route-id="@reminder.Id"
                                    class="btn btn-outline-warning btn-sm">
                                    Disable
                                </a>
                            }
                            else
                            {
                                <a asp-action="ToggleReminder"
                                    asp-route-id="@reminder.Id"
                                    class="btn btn-outline-success btn-sm">
                                    Enable
                                </a>
                            }

                        </td>

                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>