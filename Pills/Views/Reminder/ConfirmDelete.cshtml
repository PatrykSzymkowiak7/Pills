@using Pills.Domain.Models.ViewModels.Reminders
@model DeleteReminderViewModel

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="card shadow-sm">
                <div class="card-body">

                    <h3 class="text-center mb-4">
                        Are you sure you want to delete this reminder? <br />
                        This action cannot be undone.
                    </h3>

                    <form asp-action="DeleteConfirmed" method="post">
                        @Html.AntiForgeryToken()

                        <input asp-for="Id" type="hidden" /> 

                        <div class="mb-3">
                            <label asp-for="Message" class="form-label"></label>
                            <input asp-for="Message" class="form-control" type="text" readonly value="@Model.Message"/>
                            <span asp-validation-for="Message" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TimeOfDay" class="form-label"></label>
                            <input asp-for="TimeOfDay" class="form-control" type="time" readonly value="@Model.TimeOfDay"/>
                            <span asp-validation-for="TimeOfDay" class="text-danger"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-danger">
                                Delete
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>